# ─── Supabase ─────────────────────────────────────────────────────────────────
# Required for auth + database. Get these from supabase.com → Project Settings → API.
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Up Bank ──────────────────────────────────────────────────────────────────
# Dev-only fallback token for Up Bank API.
# In dev: app uses this automatically so you don't have to paste it in the UI every time.
# In production: users supply their own token through the UI (never stored server-side).
# Get yours at: https://api.up.com.au/getting_started
VITE_UP_API_TOKEN=up:yeah:your-token-here

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Set to true to store auth tokens in sessionStorage instead of localStorage.
# Useful on shared/public computers — tokens are cleared when the tab closes.
VITE_AUTH_SESSION_STORAGE=false
